# Banco de dados PostgreSQL (Supabase)
# Connection string da pooled connection (use essa pra runtime)
DATABASE_URL="postgresql://postgres.PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (use essa pra migrations)
DIRECT_DATABASE_URL="postgresql://postgres.PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# NextAuth — segredo aleatório (geração: openssl rand -hex 32)
AUTH_SECRET=""

# Necessário pra trabalhar atrás de proxy/CDN (Vercel)
AUTH_TRUST_HOST="true"

# (Opcional) URL pública do app — Vercel injeta automaticamente em deploy
# AUTH_URL="https://viafinance.vercel.app"
